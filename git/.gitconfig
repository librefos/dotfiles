[user]
	email = librefos@hotmail.com
	name = Thiago C Silva
	signingkey = AC2C6D6AEE8D538F
[commit]
	gpgSign = true
[sendemail]
	smtpserver = smtp.gmail.com
	smtpencryption = tls
	smtpserverport = 587
	smtpuser = opsrcodev@gmail.com
[alias]
	st = status
	co = checkout
	br = branch
	ci = commit
[color]
	ui = auto
